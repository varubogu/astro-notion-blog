{
  "name": "astro-notion-blog",
  "type": "module",
  "version": "0.10.0",
  "private": true,
  "scripts": {
    "dev": "astro dev --host",
    "start": "astro dev --host",
    "build": "astro build",
    "build:cached": "bun run cache:fetch && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint src",
    "format": "bun x prettier --write .",
    "cache:fetch": "bun scripts/blog-contents-cache.cjs",
    "cache:purge": "nx reset && rm -f tmp/*",
    "_fetch-notion-blocks": "bun scripts/retrieve-block-children.cjs"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@astrojs/react": "^4.4.2",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@eslint/js": "^9.39.4",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/octicon": "^1.2.24",
    "@iconify/icons-logos": "^1.2.36",
    "@notionhq/client": "^2.3.0",
    "@nrwl/nx-cloud": "^19.1.3",
    "@supercharge/promise-pool": "^3.3.0",
    "@types/async-retry": "^1.4.9",
    "@types/bun": "^1.3.14",
    "@types/katex": "^0.16.8",
    "@types/metascraper": "^5.41.0",
    "@types/metascraper-description": "^5.42.0",
    "@types/metascraper-image": "^5.42.0",
    "@types/metascraper-title": "^5.42.0",
    "@types/prismjs": "^1.26.6",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@typescript-eslint/typescript-estree": "^8.59.3",
    "astro": "^5.18.1",
    "astro-eslint-parser": "^1.4.0",
    "astro-icon": "^1.1.5",
    "async-retry": "^1.3.3",
    "axios": "^1.16.1",
    "cli-progress": "^3.12.0",
    "eslint": "^9.39.4",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "exif-be-gone": "^1.5.1",
    "globals": "^16.5.0",
    "katex": "^0.16.47",
    "mermaid": "^11.15.0",
    "metascraper": "^5.50.3",
    "metascraper-description": "^5.50.1",
    "metascraper-image": "^5.50.1",
    "metascraper-title": "^5.50.1",
    "nx": "^20.8.4",
    "prismjs": "^1.30.0",
    "sharp": "^0.34.5",
    "ts-node": "^10.9.2",
    "typescript-eslint": "^8.59.3"
  },
  "nx": {
    "targets": {
      "_fetch-notion-blocks": {
        "inputs": [
          "!{projectRoot}/**/*",
          "!{projectRoot}/**/.*",
          "!{projectRoot}/**/.*/**/*",
          {
            "env": "DATABASE_ID"
          }
        ],
        "outputs": [
          "{projectRoot}/tmp"
        ]
      }
    },
    "includedScripts": [
      "_fetch-notion-blocks"
    ]
  }
}
